# --- 1. DECORADOR PARA CRONÔMETRO ---
def cronometrar_etapa(funcao):
    @wraps(funcao)
    def wrapper(*args, **kwargs):
        inicio = time.time()
        print(f"⌛ Iniciando: {funcao.__name__.replace('_', ' ').upper()}...")
        
        resultado = funcao(*args, **kwargs)
        
        fim = time.time()
        duracao = fim - inicio
        print(f"⏱️ Concluído em: {duracao:.2f}s\n" + "-"*40)
        return resultado
    return wrapper

# --- 2. CONFIGURAÇÃO DO ROBÔ ---
class AutomacaoSuprimentos:
    def __init__(self):
        # Configuração para o navegador NÃO fechar sozinho
        chrome_options = Options()
        chrome_options.add_experimental_option("detach", True)
        
        self.driver = webdriver.Chrome(options=chrome_options)
        self.wait = WebDriverWait(self.driver, 15) # Espera inteligente de 15s

    @cronometrar_etapa
    def abrir_portal(self, url):
        self.driver.get(url) 
        self.driver.maximize_window()
    @cronometrar_etapa
    def realizar_login(self, usuario, senha):
        campo_usuario = self.wait.until(
            EC.presence_of_element_located((By.ID, "O54_id-inputEl"))
        )
        campo_senha = self.driver.find_element(By.ID, "O58_id-inputEl")
        botao_entrar = self.driver.find_element(By.ID, "O5C_id-btnIconEl")

        campo_usuario.send_keys(usuario)
        campo_senha.send_keys(senha)
        botao_entrar.click()

    @cronometrar_etapa    
    def apertar_ok(self):
        botao_ok = self.wait.until(
            EC.element_to_be_clickable((By.ID, "NXReportButton"))
        )
        botao_ok.click()
    
    @cronometrar_etapa
    def acessar_transferencia_saldos(self):
        botao_transferencia = self.wait.until(
            EC.presence_of_element_located((By.CLASS_NAME, "TransfernciadeSaldos1"))
        )
        self.driver.execute_script("arguments[0].click();", botao_transferencia)
        
    @cronometrar_etapa
    def clicar_novo_botao(self):
        icone = self.wait.until(
            EC.presence_of_element_located((By.ID, "O15D_id-btnIconEl"))
        )
        self.driver.execute_script("arguments[0].click();", icone)
    
    @cronometrar_etapa
    def clicar_calendario(self):
        time.sleep(1) # Pausa rápida para a tela estabilizar
        
        seletor_css = "div.x-form-date-trigger"
            
        botoes_calendario = self.wait.until(
                EC.visibility_of_all_elements_located((By.CSS_SELECTOR, seletor_css))
        )
            
        botao_alvo = botoes_calendario[0]
            
        self.driver.execute_script("arguments[0].click();", botao_alvo)

